# Database
DATABASE_URL=postgresql://shoplane_user:shoplane_pass@localhost:5432/shoplane_db

# Security
SECRET_KEY=shoplane-secret-key-change-this-in-production-min-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Application
APP_NAME=Shoplane
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,*.1line.az

# Domain Configuration
BASE_DOMAIN=1line.az
ADMIN_SUBDOMAIN=admin

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Subscription Plans (in AZN)
BASE_PLAN_PRICE=49
PRO_PLAN_PRICE=79

# File Upload
MAX_UPLOAD_SIZE=5242880
UPLOAD_DIR=uploads/products
