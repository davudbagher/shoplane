# ============================================================================
# 1link.az Backend - Environment Configuration
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Fill in your actual values in .env
# 3. NEVER commit .env to Git (it contains secrets!)
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# PostgreSQL connection string
# Format: postgresql://username:password@host:port/database_name
DATABASE_URL=postgresql://shoplane_user:your_password_here@localhost:5432/shoplane_db

# ============================================================================
# JWT SECURITY
# ============================================================================
# Secret key for signing JWT tokens (CHANGE THIS IN PRODUCTION!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-super-secret-jwt-key-min-32-chars-CHANGE-IN-PRODUCTION

# JWT algorithm (don't change unless you know what you're doing)
ALGORITHM=HS256

# Token expiration time in minutes (10080 = 7 days)
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================================================
# DOMAIN CONFIGURATION
# ============================================================================
# Base domain for multi-tenant routing
BASE_DOMAIN=1link.az

# Admin subdomain (for future admin panel)
ADMIN_SUBDOMAIN=admin

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
# Environment: development, staging, production
ENVIRONMENT=development

# Enable debug mode (disable in production!)
DEBUG=True

# Server host and port
HOST=0.0.0.0
PORT=8000

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
# Allowed origins for CORS (comma-separated)
# For local development: http://localhost:3000,http://localhost:5173
# For production: https://1link.az,https://*.1link.az
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://1link.az,https://*.1link.az

# ============================================================================
# FILE UPLOAD (OPTIONAL - FOR FUTURE FEATURES)
# ============================================================================
# Cloudinary for image hosting
# CLOUDINARY_CLOUD_NAME=your_cloud_name
# CLOUDINARY_API_KEY=your_api_key
# CLOUDINARY_API_SECRET=your_api_secret

# Maximum file size in MB
# MAX_FILE_SIZE_MB=5

# Allowed file types
# ALLOWED_FILE_TYPES=image/png,image/jpeg,image/webp,image/jpg

# ============================================================================
# EMAIL CONFIGURATION (OPTIONAL - FOR FUTURE NOTIFICATIONS)
# ============================================================================
# SMTP server for sending emails
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=noreply@1link.az
# SMTP_PASSWORD=your_smtp_app_password
# SMTP_FROM_EMAIL=noreply@1link.az
# SMTP_FROM_NAME=1link.az

# ============================================================================
# SMS CONFIGURATION (OPTIONAL - FOR ORDER NOTIFICATIONS)
# ============================================================================
# Azerbaijan SMS providers: Bako SMS, SMS.az, etc.
# SMS_PROVIDER=bako_sms
# SMS_API_KEY=your_sms_api_key
# SMS_API_SECRET=your_sms_secret
# SMS_SENDER_NAME=1linkAZ

# ============================================================================
# PAYMENT GATEWAY CONFIGURATION (FUTURE)
# ============================================================================
# MilliKart Payment Gateway
# MILLIKART_MERCHANT_ID=your_merchant_id
# MILLIKART_SECRET_KEY=your_secret_key
# MILLIKART_CALLBACK_URL=https://api.1link.az/payments/millikart/callback

# BirBank Payment Gateway
# BIRBANK_MERCHANT_ID=your_merchant_id
# BIRBANK_API_KEY=your_api_key
# BIRBANK_CALLBACK_URL=https://api.1link.az/payments/birbank/callback

# Pasha Pay Payment Gateway
# PASHA_PAY_MERCHANT_ID=your_merchant_id
# PASHA_PAY_API_KEY=your_api_key
# PASHA_PAY_CALLBACK_URL=https://api.1link.az/payments/pasha/callback

# ============================================================================
# CACHING (OPTIONAL - FOR PERFORMANCE)
# ============================================================================
# Redis for caching (improves performance)
# REDIS_URL=redis://localhost:6379/0
# CACHE_TTL_SECONDS=3600

# ============================================================================
# MONITORING & LOGGING (OPTIONAL)
# ============================================================================
# Sentry for error tracking
# SENTRY_DSN=your_sentry_dsn

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ============================================================================
# SUBSCRIPTION PLANS (CONFIGURED IN CODE, BUT CAN BE OVERRIDDEN)
# ============================================================================
# BASE plan monthly price in AZN
# BASE_PLAN_PRICE=0.00

# PRO plan monthly price in AZN
# PRO_PLAN_PRICE=79.00

# ============================================================================
# RATE LIMITING (OPTIONAL - FOR SECURITY)
# ============================================================================
# API rate limits (requests per minute)
# RATE_LIMIT_PER_MINUTE=60
# RATE_LIMIT_BURST=10

# ============================================================================
# FEATURE FLAGS (OPTIONAL - FOR GRADUAL ROLLOUTS)
# ============================================================================
# Enable/disable features without code changes
# FEATURE_MARKETPLACE_SEARCH=false
# FEATURE_PRODUCT_COMPARISON=false
# FEATURE_ML_RECOMMENDATIONS=false
# FEATURE_BULK_UPLOAD=false

# ============================================================================
# DEVELOPMENT HELPERS
# ============================================================================
# Auto-reload on code changes (development only)
# RELOAD=True

# Show SQL queries in logs (development only)
# ECHO_SQL=False
